# Skip onnxruntime-node's postinstall download of the CUDA/TensorRT execution-provider
# libraries. We run CPU-only inference and Vercel has no GPU, so those (hundreds of MB)
# are dead weight that also broke the 250MB serverless-function limit when traced in.
# The CPU runtime (libonnxruntime.so.1) is bundled in the npm package and unaffected.
# Read by onnxruntime-node/script/install-utils.js via npm_config_onnxruntime_node_install.
onnxruntime-node-install=skip
